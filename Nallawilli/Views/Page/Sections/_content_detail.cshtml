@model CmsPublicSectionViewModel
@using Nallawilli.Helpers.Public

@{
    var title = Model.Get("title");
    var description = Model.Get("description");
    var bgImage = Model.Get("image");
    var bgImageUrl = CmsMediaPaths.ToAppRelative(bgImage);
}

<section class="bg-default page-next-level" style="background: url('@(bgImageUrl is null ? "" : Url.Content(bgImageUrl))') center no-repeat;">
    <div class="home-center">
        <div class="home-desc-center">
            <div class="container">
                <div class="row align-items-center">
                    <div class="col-12">
                        <div class="text-center d-flex justify-content-center">
                            <h3 class="title-pager mb-0 text-light"> @title </h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="row">
            <div class="col-lg-12 col-md-12 mt-4 pt-2">
                <div class="card blog blog-primary overflow-hidden border-0">

                    <h3 class="mb-3 ps-4">@title</h3>
                    
                    <div class="card-img image position-relative overflow-hidden">

                        <div class="position-relative overflow-hidden mx-4 mt-4 rounded">
                            <img src="@bgImage" class="img-fluid" alt="">
                            <div class="bg">
                                <div class="bg-overlay bg-gradient"></div>
                            </div>
                        </div>
                    </div>

                    <div class="card-body content p-0">
                        <div class="p-4">
                            <p class="text-muted">
                                @Html.Raw(description)
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>