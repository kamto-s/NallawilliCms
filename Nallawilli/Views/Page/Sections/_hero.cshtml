@using Nallawilli.ViewModels
@model CmsPublicSectionViewModel
@{
    var eyebrow = Model.Get("eyebrow") ?? Model.Get("subtitle");
    var title = Model.Get("title");
    var backgroundImage = Model.Get("background_image") ?? Model.Get("image");
    var backgroundImageUrl = string.IsNullOrWhiteSpace(backgroundImage)
        ? Url.Content("~/assets/public/img/hero-carousel/hero.jpg")
        : backgroundImage;
}



