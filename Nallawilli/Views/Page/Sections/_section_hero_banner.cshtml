@model CmsPublicSectionViewModel

@{
    var subtitle = Model.Get("subtitle");
    var title = Model.Get("title");
    var bgImage = Model.Get("bg_image");
}

<section class="bg-home d-flex align-items-center overflow-hidden position-relative"
         id="home"
         style="min-height: 100vh; background-image: url('@Url.Content(@bgImage)'); background-repeat: no-repeat; background-size: cover; background-position: center center;">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 col-md-6 col-sm-12 text-start">
                <div class="title-heading">
                    <p class="para-desc text-light">@subtitle</p>
                    <h1 class="heading mb-4 fw-bold text-light">@title</h1>
                </div>
            </div>
        </div>
    </div>
</section>