@model CmsPublicSectionViewModel

@{
    var title = Model.Get("title");
    var subtitle = Model.Get("subtitle");
    var image = Model.Get("image");
    var description = Model.Get("description");
    var buttonText = Model.Get("button_text");
    var buttonUrl = Model.Get("button_url");

}

<section class="section about-section" id="about">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-6 mt-4 mt-sm-0 pt-2 pt-sm-0">
                <div class="section-title ms-lg-4 mb-0">
                    <span class="badge bg-soft-primary text-uppercase text-primary py-2 px-3 rounded-pill mb-2">@subtitle</span>
                    <h3 class="title mb-4">@title</h3>
                    <p class="text-muted">
                        @Html.Raw(description)
                    </p>
                    <div class="mt-3">
                        <a href="@buttonUrl" class="btn btn-primary">@buttonText</a>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="about-img position-relative">
                    <img src="@image" class="" alt="@title">
                </div>
            </div>
        </div>
    </div>
</section>