@using Microsoft.AspNetCore.Identity

@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<header id="topnav" class="defaultscroll sticky">
    <div class="container">
        <!-- Logo container-->
        <a class="logo" asp-controller="Page" asp-action="Index">
            <span class="logo-light-mode">
                <img src="~/assets/public/images/logo-dark.png" class="l-dark" alt="" style="max-height:64px !important;">
                <img src="~/assets/public/images/logo-light.png" class="l-light" alt="" style="max-height:64px !important;">
            </span>
            <img src="~/assets/public/images/logo-light.png" class="logo-dark-mode" alt="">
        </a>
        <!-- End Logo container-->
        <div class="menu-extras">
            <div class="menu-item">
                <!-- Mobile menu toggle-->
                <a class="navbar-toggle" id="isToggle" onclick="toggleMenu()">
                    <div class="lines">
                        <span></span>
                        <span></span>
                        <span></span>
                    </div>
                </a>
                <!-- End mobile menu toggle-->
            </div>
        </div>

        <div id="navigation">
            <!-- Navigation Menu-->
            <ul class="navigation-menu nav-light nav-right">
                @await Component.InvokeAsync("PublicMenu")
                @if (SignInManager.IsSignedIn(User))
                {
                    <li>
                        <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                           Dashboard
                        </a>
                    </li>
                }
                else
                {
                    <li>
                        <a class="sub-menu-item" id="register" asp-area="Identity" asp-page="/Account/Register">Register</a>
                    </li>
                    <li>
                        <a class="sub-menu-item" id="login" asp-area="Identity" asp-page="/Account/Login">Login</a>
                    </li>
                }
            </ul>
        </div>
        <!--end navigation-->
    </div>
    <!--end container-->
</header>

