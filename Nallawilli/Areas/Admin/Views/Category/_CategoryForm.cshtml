@model CategoryFormViewModel

<div asp-validation-summary="ModelOnly" class="text-danger mb-16"></div>

<div class="row gy-3">
    <div class="col-12">
        <label asp-for="Name" class="form-label text-gray-600 text-13 fw-medium"></label>
        <input asp-for="Name" class="form-control" autocomplete="off" />
        <span asp-validation-for="Name" class="text-danger text-12"></span>
    </div>
    <div class="col-12">
        <label asp-for="Description" class="form-label text-gray-600 text-13 fw-medium"></label>
        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Description" class="text-danger text-12"></span>
    </div>
</div>
