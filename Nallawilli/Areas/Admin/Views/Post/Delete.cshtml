@model Nallawilli.Models.Entities.Post
@using System.Text.Json
@using Nallawilli.Models.Enums
@{
    ViewData["Title"] = "Delete post";
    var flashError = TempData["Error"] as string;
    var deletePageJson = JsonSerializer.Serialize(
        new { flashError, postTitle = Model.Title },
        new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase });
}

<div class="breadcrumb mb-24">
    <ul class="flex-align gap-4">
        <li><a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="text-gray-200 fw-normal text-15 hover-text-main-600">Dashboard</a></li>
        <li><span class="text-gray-500 fw-normal d-flex"><i class="ph ph-caret-right"></i></span></li>
        <li><a asp-area="Admin" asp-controller="Post" asp-action="Index" class="text-gray-200 fw-normal text-15 hover-text-main-600">Posts</a></li>
        <li><span class="text-gray-500 fw-normal d-flex"><i class="ph ph-caret-right"></i></span></li>
        <li><span class="text-main-600 fw-normal text-15">Delete</span></li>
    </ul>
</div>

<div class="card mt-24">
    <div class="card-body">
        <h4 class="mb-12">Delete post</h4>
        <p class="text-gray-600 mb-20">This action will archive the post (soft delete). It will no longer appear in lists.</p>

        <dl class="row mb-24">
            <dt class="col-sm-3 text-gray-600">Title</dt>
            <dd class="col-sm-9 fw-medium">@Model.Title</dd>
            <dt class="col-sm-3 text-gray-600">Slug</dt>
            <dd class="col-sm-9"><code class="text-main-600">@Model.Slug</code></dd>
            <dt class="col-sm-3 text-gray-600">Status</dt>
            <dd class="col-sm-9">
                @{
                    var statusBadge = Model.Status switch
                    {
                        ContentStatus.Published => "badge rounded-pill bg-success-50 text-success-600",
                        ContentStatus.Scheduled => "badge rounded-pill bg-warning-50 text-warning-600",
                        _ => "badge rounded-pill bg-gray-100 text-gray-600"
                    };
                }
                <span class="@statusBadge">@Model.Status</span>
            </dd>
            <dt class="col-sm-3 text-gray-600">Category</dt>
            <dd class="col-sm-9">@(Model.Category?.Name ?? "—")</dd>
        </dl>

        <form id="post-delete-confirm-form" asp-area="Admin" asp-controller="Post" asp-action="Delete" asp-route-id="@Model.Id" method="post" class="flex-align gap-12">
            @Html.AntiForgeryToken()
            <button type="button" id="btn-delete-post-confirm" class="btn btn-danger rounded-pill px-24">Delete</button>
            <a asp-area="Admin" asp-controller="Post" asp-action="Index" class="btn border border-gray-200 text-gray-600 rounded-pill px-24 hover-border-main-600 hover-text-main-600">Cancel</a>
        </form>
    </div>
</div>

<script type="application/json" id="post-delete-page-data">@Html.Raw(deletePageJson)</script>

@section Scripts {
    <script src="~/assets/admin/js/post/delete-page.js" asp-append-version="true"></script>
}
