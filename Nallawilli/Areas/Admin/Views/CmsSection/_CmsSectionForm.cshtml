@model CmsSectionFormViewModel

<div asp-validation-summary="All" class="text-danger mb-16"></div>

<div class="row gy-3">
    <div class="col-12">
        <label asp-for="SectionCode" class="form-label text-gray-600 text-13 fw-medium"></label>
        <input asp-for="SectionCode" class="form-control" autocomplete="off" placeholder="hero" />
        <span asp-validation-for="SectionCode" class="text-danger text-12"></span>
        <p class="text-gray-500 text-12 mt-8 mb-0">e.g. hero, _hero, hero-main. Saved as lowercase.</p>
    </div>
    <div class="col-12">
        <label asp-for="SectionName" class="form-label text-gray-600 text-13 fw-medium"></label>
        <input asp-for="SectionName" class="form-control" autocomplete="off" />
        <span asp-validation-for="SectionName" class="text-danger text-12"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="SortOrder" class="form-label text-gray-600 text-13 fw-medium"></label>
        <input asp-for="SortOrder" class="form-control" type="number" />
        <span asp-validation-for="SortOrder" class="text-danger text-12"></span>
    </div>
    <div class="col-md-6">
        <div class="form-check mt-32">
            <input asp-for="IsActive" class="form-check-input" />
            <label asp-for="IsActive" class="form-check-label text-gray-600 text-13"></label>
        </div>
    </div>
</div>
