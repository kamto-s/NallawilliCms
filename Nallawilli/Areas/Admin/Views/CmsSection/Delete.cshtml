@model Nallawilli.Models.Entities.CmsSection
@{
    ViewData["Title"] = "Delete section";
    var contentCount = ViewBag.ContentCount as int? ?? 0;
    var pageId = (Guid)ViewBag.PageId!;
}

<div class="card mt-24">
    <div class="card-body">
        <h4 class="mb-12">Delete section</h4>
        <p class="text-gray-600 mb-20">Archives this section and its content items.</p>
        <dl class="row mb-24">
            <dt class="col-sm-3">Code</dt>
            <dd class="col-sm-9"><code>@Model.SectionCode</code></dd>
            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.SectionName</dd>
            <dt class="col-sm-3">Contents</dt>
            <dd class="col-sm-9">@contentCount</dd>
        </dl>
        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="flex-align gap-12">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger rounded-pill px-24">Delete</button>
            <a asp-action="Index" asp-route-pageId="@pageId" class="btn border border-gray-200 text-gray-600 rounded-pill px-24">Cancel</a>
        </form>
    </div>
</div>
